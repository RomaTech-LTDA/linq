{
  "name": "@romatech/linq",
  "version": "2.0.0",
  "description": "LINQ for JavaScript with lazy evaluation. Extends arrays with a deferred LazyQuery pipeline inspired by C# IEnumerable<T>. Supports filtering, projection, joining, grouping, sorting, set operations, aggregation, and short-circuit iteration — all with a fluent syntax and zero intermediate allocations.",
  "author": "RomaTech/Leandro Romanelli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/romatech-ltda/linq.git"
  },
  "homepage": "https://github.com/romatech-ltda/linq#readme",
  "bugs": {
    "url": "https://github.com/romatech-ltda/linq/issues"
  },
  "license": "MIT",
  "main": "./index.js",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.js"
    }
  },
  "sideEffects": true,
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=11"
  },
  "keywords": [
    "linq",
    "lazy",
    "query",
    "deferred",
    "enumerable",
    "array",
    "pipeline",
    "where",
    "select",
    "groupBy",
    "orderBy",
    "IEnumerable",
    "csharp",
    "dotnet",
    "javascript",
    "typescript"
  ],
  "scripts": {
    "test": "jest",
    "prepublishOnly": "npm test"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "moduleFileExtensions": ["js"],
    "transform": {},
    "testPathIgnorePatterns": ["/node_modules/"],
    "verbose": true
  }
}
